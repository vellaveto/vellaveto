{
  "Vellaveto Dev Laptop Preset": {
    "prefix": "vellaveto-preset-dev",
    "description": "Developer laptop agent preset - protects credentials, requires approval for destructive commands",
    "body": [
      "# Vellaveto Preset: Developer Laptop Agent",
      "",
      "[[policies]]",
      "name = \"Block credential files\"",
      "tool_pattern = \"*\"",
      "function_pattern = \"*\"",
      "priority = 300",
      "id = \"dev:*:credential-block\"",
      "",
      "[policies.policy_type.Conditional.conditions]",
      "on_no_match = \"continue\"",
      "parameter_constraints = [",
      "  { param = \"*\", op = \"glob\", pattern = \"/home/*/.aws/**\", on_match = \"deny\", on_missing = \"skip\" },",
      "  { param = \"*\", op = \"glob\", pattern = \"/home/*/.ssh/**\", on_match = \"deny\", on_missing = \"skip\" },",
      "  { param = \"*\", op = \"glob\", pattern = \"**/.env\", on_match = \"deny\", on_missing = \"skip\" },",
      "]",
      "",
      "[[policies]]",
      "name = \"Default allow for dev\"",
      "tool_pattern = \"*\"",
      "function_pattern = \"*\"",
      "priority = 1",
      "id = \"dev:*:default-allow\"",
      "policy_type = \"Allow\"",
      "",
      "[injection]",
      "enabled = true",
      "blocking = false"
    ]
  },
  "Vellaveto CI Agent Preset": {
    "prefix": "vellaveto-preset-ci",
    "description": "CI/CD agent preset - strict network controls, blocking injection/DLP",
    "body": [
      "# Vellaveto Preset: CI/CD Agent",
      "",
      "[[policies]]",
      "name = \"Block credential access in CI\"",
      "tool_pattern = \"*\"",
      "function_pattern = \"*\"",
      "priority = 300",
      "id = \"ci:*:credential-block\"",
      "",
      "[policies.policy_type.Conditional.conditions]",
      "on_no_match = \"continue\"",
      "parameter_constraints = [",
      "  { param = \"*\", op = \"glob\", pattern = \"**/.env\", on_match = \"deny\", on_missing = \"skip\" },",
      "  { param = \"*\", op = \"glob\", pattern = \"**/secrets*\", on_match = \"deny\", on_missing = \"skip\" },",
      "]",
      "",
      "[[policies]]",
      "name = \"Network allowlist\"",
      "tool_pattern = \"*\"",
      "function_pattern = \"*\"",
      "priority = 250",
      "id = \"ci:*:network-allowlist\"",
      "",
      "[policies.network_rules]",
      "allowed_domains = [\"github.com\", \"api.github.com\", \"registry.npmjs.org\"]",
      "blocked_domains = []",
      "",
      "[policies.network_rules.ip_rules]",
      "block_private = true",
      "",
      "[[policies]]",
      "name = \"Default allow for CI\"",
      "tool_pattern = \"*\"",
      "function_pattern = \"*\"",
      "priority = 1",
      "id = \"ci:*:default-allow\"",
      "policy_type = \"Allow\"",
      "",
      "[injection]",
      "enabled = true",
      "blocking = true",
      "",
      "[dlp]",
      "enabled = true",
      "blocking = true"
    ]
  },
  "Vellaveto Database Agent Preset": {
    "prefix": "vellaveto-preset-database",
    "description": "Database agent preset - blocks destructive DDL, requires approval for drops",
    "body": [
      "# Vellaveto Preset: Database Agent",
      "",
      "[[policies]]",
      "name = \"Require approval for destructive operations\"",
      "tool_pattern = \"*\"",
      "function_pattern = \"*\"",
      "priority = 250",
      "id = \"db:*:destructive-sql\"",
      "",
      "[policies.policy_type.Conditional.conditions]",
      "on_no_match = \"continue\"",
      "parameter_constraints = [",
      "  { param = \"*\", op = \"regex\", pattern = \"(?i)DROP\\\\s+(TABLE|DATABASE)\", on_match = \"require_approval\", on_missing = \"skip\" },",
      "  { param = \"*\", op = \"regex\", pattern = \"(?i)TRUNCATE\\\\s+\", on_match = \"require_approval\", on_missing = \"skip\" },",
      "  { param = \"*\", op = \"regex\", pattern = \"(?i)GRANT\\\\s+ALL\", on_match = \"deny\", on_missing = \"skip\" },",
      "]",
      "",
      "[[policies]]",
      "name = \"Default allow for database\"",
      "tool_pattern = \"*\"",
      "function_pattern = \"*\"",
      "priority = 1",
      "id = \"db:*:default-allow\"",
      "policy_type = \"Allow\"",
      "",
      "[dlp]",
      "enabled = true",
      "blocking = true",
      "scan_responses = true"
    ]
  },
  "Vellaveto Browser Agent Preset": {
    "prefix": "vellaveto-preset-browser",
    "description": "Browser automation agent preset - blocks malicious domains, restricts downloads",
    "body": [
      "# Vellaveto Preset: Browser Agent",
      "",
      "[[policies]]",
      "name = \"Block malicious domains\"",
      "tool_pattern = \"*\"",
      "function_pattern = \"*\"",
      "priority = 250",
      "id = \"browser:*:domain-block\"",
      "",
      "[policies.network_rules]",
      "allowed_domains = []",
      "blocked_domains = [\"pastebin.com\", \"transfer.sh\", \"file.io\", \"webhook.site\"]",
      "",
      "[policies.network_rules.ip_rules]",
      "block_private = true",
      "",
      "[[policies]]",
      "name = \"Default allow for browser\"",
      "tool_pattern = \"*\"",
      "function_pattern = \"*\"",
      "priority = 1",
      "id = \"browser:*:default-allow\"",
      "policy_type = \"Allow\"",
      "",
      "[injection]",
      "enabled = true",
      "blocking = true",
      "",
      "[dlp]",
      "enabled = true",
      "blocking = true"
    ]
  },
  "Vellaveto RAG Agent Preset": {
    "prefix": "vellaveto-preset-rag",
    "description": "RAG agent preset - prevents data exfiltration, injection via retrieved documents",
    "body": [
      "# Vellaveto Preset: RAG Agent",
      "",
      "[[policies]]",
      "name = \"Block credential files\"",
      "tool_pattern = \"*\"",
      "function_pattern = \"*\"",
      "priority = 300",
      "id = \"rag:*:credential-block\"",
      "",
      "[policies.policy_type.Conditional.conditions]",
      "on_no_match = \"continue\"",
      "parameter_constraints = [",
      "  { param = \"*\", op = \"glob\", pattern = \"**/.env\", on_match = \"deny\", on_missing = \"skip\" },",
      "  { param = \"*\", op = \"glob\", pattern = \"**/secrets*\", on_match = \"deny\", on_missing = \"skip\" },",
      "]",
      "",
      "[[policies]]",
      "name = \"Restrict network to data sources\"",
      "tool_pattern = \"*\"",
