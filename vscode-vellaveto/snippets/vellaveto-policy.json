  "Vellaveto Policy Block": {
    "prefix": "vellaveto-policy",
    "description": "Add a new policy rule",
    "body": [
      "[[policies]]",
      "name = \"${1:policy-name}\"",
      "tool_pattern = \"${2:*}\"",
      "function_pattern = \"${3:*}\"",
      "priority = ${4:100}",
      "id = \"${5:namespace}:${6:tool}:${7:rule}\"",
      "policy_type = \"${8|Allow,Deny|}\"",
      "$0"
    ]
  },
  "Vellaveto Conditional Policy": {
    "prefix": "vellaveto-conditional",
    "description": "Add a conditional policy with parameter constraints",
    "body": [
      "[[policies]]",
      "name = \"${1:conditional-rule}\"",
      "tool_pattern = \"${2:*}\"",
      "function_pattern = \"${3:*}\"",
      "priority = ${4:100}",
      "id = \"${5:ns}:${6:tool}:${7:rule}\"",
      "",
      "[policies.policy_type.Conditional.conditions]",
      "on_no_match = \"${8|continue,deny,allow|}\"",
      "parameter_constraints = [",
      "  { param = \"${9:*}\", op = \"${10|glob,regex|}\", pattern = \"${11:pattern}\", on_match = \"${12|deny,require_approval,allow|}\", on_missing = \"skip\" },",
      "]",
      "$0"
    ]
  },
  "Vellaveto Network Rules": {
    "prefix": "vellaveto-network",
    "description": "Add network rules to a policy",
    "body": [
      "[policies.network_rules]",
      "allowed_domains = [${1:}]",
      "blocked_domains = [${2:}]",
      "",
      "[policies.network_rules.ip_rules]",
      "block_private = ${3|true,false|}",
      "$0"
    ]
  },
  "Vellaveto Path Rules": {
    "prefix": "vellaveto-paths",
    "description": "Add path rules to a policy",
    "body": [
      "[policies.path_rules]",
      "allowed_globs = [\"${1:/safe/path/**}\"]",
      "blocked_globs = [\"${2:/etc/**}\"]",
      "$0"
    ]
  }
}
