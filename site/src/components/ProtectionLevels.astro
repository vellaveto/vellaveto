---
---
<section id="protection-levels">
  <div class="wrap">
    <h2 class="section-title">Zero-config protection</h2>
    <p class="section-sub">Pick a level and go &mdash; no policy files, no security domain knowledge needed.</p>
    <div class="levels-grid">
      <div class="card level level-shield">
        <div class="level-header">
          <span class="level-name">Shield</span>
          <span class="level-badge">Entry-level</span>
        </div>
        <div class="level-default">Default: <strong>Allow</strong></div>
        <ul class="level-features">
          <li>Block credential files (.aws, .ssh, .env, ...)</li>
          <li>SANDWORM defense (AI config injection prevention)</li>
          <li>Exfiltration domain blocking (pastebin, ngrok, ...)</li>
          <li>Git hook &amp; system file protection</li>
          <li>Dangerous command blocking + destructive git approval</li>
          <li>Injection scanning + DLP credential leak detection</li>
        </ul>
        <div class="level-install">
          <code>vellaveto-proxy --protect shield -- ./server</code>
        </div>
      </div>
      <div class="card level level-fortress">
        <div class="level-header">
          <span class="level-name">Fortress</span>
          <span class="level-badge level-badge-rec">Recommended</span>
        </div>
        <div class="level-default">Default: <strong>Allow</strong></div>
        <ul class="level-features">
          <li>Everything in Shield, plus:</li>
          <li>System file protection (/etc/shadow, crontab, systemd)</li>
          <li>Package config tampering defense (.npmrc, pip.conf, ...)</li>
          <li>Privilege escalation approval (sudo, su, doas)</li>
          <li>Memory poisoning detection (blocking)</li>
          <li>Shadow agent detection</li>
        </ul>
        <div class="level-install">
          <code>vellaveto-proxy --protect fortress -- ./server</code>
        </div>
      </div>
      <div class="card level level-vault">
        <div class="level-header">
          <span class="level-name">Vault</span>
          <span class="level-badge">Maximum</span>
        </div>
        <div class="level-default">Default: <strong class="deny-text">Deny</strong></div>
        <ul class="level-features">
          <li>Everything in Fortress, plus:</li>
          <li>Default deny &mdash; nothing runs without permission</li>
          <li>Source code reading allowed (safe by design)</li>
          <li>Read-only git commands allowed</li>
          <li>File writes require human approval</li>
          <li>Elicitation controls enabled</li>
        </ul>
        <div class="level-install">
          <code>vellaveto-proxy --protect vault -- ./server</code>
        </div>
      </div>
    </div>
    <div class="threat-comparison">
      <h3 class="threat-title">What each level defends against</h3>
      <table class="threat-table">
        <thead>
          <tr>
            <th>Attack</th>
            <th>Shield</th>
            <th>Fortress</th>
            <th>Vault</th>
          </tr>
        </thead>
        <tbody>
          <tr><td>Credential theft (.aws, .ssh, .env)</td><td class="y">Block</td><td class="y">Block</td><td class="y">Block</td></tr>
          <tr><td>SANDWORM AI config injection</td><td class="y">Block</td><td class="y">Block</td><td class="y">Block</td></tr>
          <tr><td>Data exfiltration (pastebin, ngrok)</td><td class="y">Block</td><td class="y">Block</td><td class="y">Block</td></tr>
          <tr><td>Git hook persistence</td><td class="y">Block</td><td class="y">Block</td><td class="y">Block</td></tr>
          <tr><td>System file tampering</td><td class="y">Block</td><td class="y">Block</td><td class="y">Block</td></tr>
          <tr><td>Dangerous commands (rm -rf, curl|sh)</td><td class="y">Block</td><td class="y">Block</td><td class="y">Block</td></tr>
          <tr><td>Prompt injection</td><td class="y">Block</td><td class="y">Block</td><td class="y">Block</td></tr>
          <tr><td>Credential leaks in responses (DLP)</td><td class="y">Block</td><td class="y">Block</td><td class="y">Block</td></tr>
          <tr><td>Package registry hijacking</td><td class="n">&mdash;</td><td class="y">Block</td><td class="y">Block</td></tr>
          <tr><td>Privilege escalation (sudo)</td><td class="n">&mdash;</td><td class="a">Approve</td><td class="y">Block</td></tr>
          <tr><td>Memory poisoning</td><td class="m">Monitor</td><td class="y">Block</td><td class="y">Block</td></tr>
          <tr><td>Shadow agent detection</td><td class="n">&mdash;</td><td class="y">Detect</td><td class="y">Detect</td></tr>
          <tr><td>Unauthorized file writes</td><td class="n">&mdash;</td><td class="n">&mdash;</td><td class="a">Approve</td></tr>
          <tr><td>Destructive git ops (force push)</td><td class="a">Approve</td><td class="a">Approve</td><td class="y">Block</td></tr>
        </tbody>
      </table>
    </div>
  </div>
</section>

<style>
  .threat-comparison{margin-top:3rem}
  .threat-title{font-size:1rem;font-weight:700;color:var(--text);margin-bottom:1rem}
  .threat-table{width:100%;border-collapse:collapse;font-size:.8rem}
  .threat-table th{text-align:left;padding:.5rem .75rem;border-bottom:2px solid var(--border);
    color:var(--muted);font-weight:600;font-size:.7rem;text-transform:uppercase;letter-spacing:.04em}
  .threat-table td{padding:.4rem .75rem;border-bottom:1px solid var(--border);color:var(--muted)}
  .threat-table td:first-child{color:var(--text);font-weight:500}
  .threat-table .y{color:var(--emerald, #34d399);font-weight:600}
  .threat-table .a{color:var(--amber, #fbbf24);font-weight:600}
  .threat-table .m{color:var(--cyan, #22d3ee);font-weight:500}
  .threat-table .n{color:var(--muted);opacity:.5}
  #protection-levels{position:relative}
  .levels-grid{display:grid;grid-template-columns:repeat(auto-fit,minmax(280px,1fr));
    gap:1.25rem;margin-top:2.5rem}
  .level{padding:1.75rem;position:relative;transition:border-color .2s}
  .level-header{display:flex;align-items:center;justify-content:space-between;margin-bottom:.75rem}
  .level-name{font-size:1.15rem;font-weight:800;color:var(--text)}
  .level-badge{font-size:.65rem;font-weight:600;padding:.2rem .6rem;border-radius:1rem;
    text-transform:uppercase;letter-spacing:.05em;background:var(--surface);
    border:1px solid var(--border);color:var(--muted)}
  .level-badge-rec{background:rgba(192,75,240,.12);border-color:rgba(192,75,240,.3);color:var(--magenta)}
  .level-default{font-size:.8rem;color:var(--muted);margin-bottom:1rem}
  .level-default strong{color:var(--emerald, #34d399)}
  .deny-text{color:var(--rose, #fb7185) !important}
  .level-features{list-style:none;margin-bottom:1.25rem}
  .level-features li{font-size:.825rem;color:var(--muted);padding:.3rem 0;
    padding-left:1.25rem;position:relative;line-height:1.5}
  .level-features li::before{content:"";position:absolute;left:0;top:.65rem;
    width:6px;height:6px;border-radius:50%;background:var(--border)}
  .level-features li:first-child::before{background:var(--cyan)}
  .level-install{background:var(--surface);border:1px solid var(--border);
    border-radius:.375rem;padding:.6rem .85rem;overflow-x:auto}
  .level-install code{font-family:var(--mono);font-size:.75rem;color:var(--cyan);white-space:nowrap}

  .level-fortress{border-color:rgba(192,75,240,.25)}
  .level-fortress:hover{border-color:rgba(192,75,240,.5)}

  @media(max-width:600px){
    .levels-grid{grid-template-columns:1fr}
  }
</style>
