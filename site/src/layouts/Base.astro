---
interface Props {
  title: string;
  description?: string;
}

const { title, description = 'Agentic security control plane for MCP and AI agent tool calls. Govern identity, policy, discovery, and audit with an MCP-native gateway.' } = Astro.props;
---
<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>{title}</title>
  <meta name="description" content={description}>
  <link rel="icon" type="image/svg+xml" href="/favicon.svg">
  <link rel="icon" type="image/x-icon" href="/favicon.ico">
  <meta http-equiv="Content-Security-Policy" content="default-src 'self'; style-src 'self' 'unsafe-inline'; img-src 'self' data:; script-src 'none'; frame-ancestors 'none'; base-uri 'self'; form-action 'self'">
  <meta property="og:title" content={title}>
  <meta property="og:description" content={description}>
  <meta property="og:type" content="website">
  <meta property="og:image" content="/og-card.png">
  <meta name="twitter:card" content="summary_large_image">
  <meta name="twitter:title" content={title}>
  <meta name="twitter:description" content={description}>
  <meta name="twitter:image" content="/og-card.png">
</head>
<body>
  <nav aria-label="Main navigation">
    <div class="wrap">
      <a href="/" class="logo"><img src="/favicon.svg" alt="" width="24" height="24" class="logo-icon">VELLAVETO</a>
      <div class="nav-links">
        <a href="/#features">Features</a>
        <a href="/pricing">Pricing</a>
        <a href="/compliance">Compliance</a>
        <a href="https://github.com/vellaveto/vellaveto" target="_blank" rel="noopener noreferrer">GitHub</a>
        <a href="/#install" class="btn btn-primary btn-sm nav-cta">Get Started</a>
      </div>
    </div>
  </nav>

  <slot />

  <footer>
    <div class="wrap">
      <div class="footer-grid">
        <div class="footer-col">
          <h4>Product</h4>
          <a href="/#features">Features</a>
          <a href="/pricing">Pricing</a>
          <a href="/compliance">Compliance</a>
          <a href="https://github.com/vellaveto/vellaveto/tree/main/docs" target="_blank" rel="noopener noreferrer">Documentation</a>
        </div>
        <div class="footer-col">
          <h4>Resources</h4>
          <a href="https://github.com/vellaveto/vellaveto" target="_blank" rel="noopener noreferrer">GitHub</a>
          <a href="https://github.com/vellaveto/vellaveto/tree/main/docs" target="_blank" rel="noopener noreferrer">Quickstart</a>
          <a href="https://github.com/vellaveto/vellaveto/tree/main/docs" target="_blank" rel="noopener noreferrer">API Reference</a>
          <a href="https://github.com/vellaveto/vellaveto/tree/main/docs/SECURITY_MODEL.md" target="_blank" rel="noopener noreferrer">Security Model</a>
        </div>
        <div class="footer-col">
          <h4>Legal</h4>
          <a href="https://github.com/vellaveto/vellaveto/blob/main/LICENSING.md" target="_blank" rel="noopener noreferrer">Licensing</a>
          <a href="https://github.com/vellaveto/vellaveto/blob/main/CLA.md" target="_blank" rel="noopener noreferrer">CLA</a>
          <a href="/compliance">Privacy Policy</a>
        </div>
        <div class="footer-col">
          <h4>Company</h4>
          <p>Made in Italy</p>
          <a href="&#109;&#97;&#105;&#108;&#116;&#111;&#58;paolovella1993&#64;gmail&#46;com">paolovella1993&#64;gmail.com</a>
          <p class="copy">Built by <strong>Paolo Vella</strong></p>
        </div>
      </div>
      <div class="footer-bottom">
        <p>&copy; 2026 Vellaveto. See LICENSING.md for current licensing terms.</p>
      </div>
    </div>
  </footer>
</body>
</html>

<style is:global>
  @import '../styles/global.css';

  /* Nav */
  nav{position:fixed;top:0;left:0;right:0;z-index:100;
    background:rgba(10,14,23,.85);backdrop-filter:blur(12px);
    border-bottom:1px solid var(--border)}
  nav::after{content:'';position:absolute;bottom:-1px;left:0;right:0;
    height:1px;background:var(--grad);opacity:.5}
  nav .wrap{display:flex;align-items:center;justify-content:space-between;
    height:3.5rem}
  .logo{display:flex;align-items:center;gap:.5rem;font-weight:700;font-size:1.1rem;letter-spacing:.04em;
    background:var(--grad);-webkit-background-clip:text;
    -webkit-text-fill-color:transparent}
  .logo-icon{-webkit-text-fill-color:initial;flex-shrink:0}
  .nav-links{display:flex;align-items:center}
  .nav-links a{margin-left:1.5rem;font-size:.875rem;color:var(--muted)}
  .nav-links a:hover{color:var(--text)}
  .nav-cta{margin-left:1.5rem;color:#0a0e17 !important}

  /* Footer */
  footer{border-top:1px solid var(--border);padding:3.5rem 0 2rem;
    font-size:.85rem;color:var(--muted)}
  .footer-grid{display:grid;grid-template-columns:repeat(4,1fr);gap:2rem}
  .footer-col{display:flex;flex-direction:column;gap:.5rem}
  .footer-col h4{color:var(--text);font-size:.8rem;font-weight:600;
    text-transform:uppercase;letter-spacing:.06em;margin-bottom:.25rem}
  .footer-col a{color:var(--muted);font-size:.85rem}
  .footer-col a:hover{color:var(--accent)}
  .footer-col p{font-size:.85rem}
  .footer-col .copy{margin-top:.25rem;font-size:.75rem}
  .footer-bottom{margin-top:2.5rem;padding-top:1.5rem;
    border-top:1px solid var(--border);text-align:center;font-size:.75rem}

  @media(max-width:600px){
    .nav-links a{margin-left:.75rem;font-size:.8rem}
    .nav-cta{display:none}
    .footer-grid{grid-template-columns:repeat(2,1fr);gap:1.5rem}
  }
</style>
