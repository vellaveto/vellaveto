{
  "annotations": {
    "list": []
  },
  "description": "Vellaveto evaluation latency: P50/P95/P99, injection scan time, DLP scan time",
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "links": [],
  "panels": [
    {
      "title": "Evaluation Latency (P50 / P95 / P99)",
      "type": "timeseries",
      "gridPos": { "h": 10, "w": 12, "x": 0, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": {
          "unit": "ms"
        }
      },
      "targets": [
        {
          "expr": "histogram_quantile(0.50, sum(rate(vellaveto_evaluation_duration_seconds_bucket[$__rate_interval])) by (le)) * 1000",
          "legendFormat": "P50"
        },
        {
          "expr": "histogram_quantile(0.95, sum(rate(vellaveto_evaluation_duration_seconds_bucket[$__rate_interval])) by (le)) * 1000",
          "legendFormat": "P95"
        },
        {
          "expr": "histogram_quantile(0.99, sum(rate(vellaveto_evaluation_duration_seconds_bucket[$__rate_interval])) by (le)) * 1000",
          "legendFormat": "P99"
        }
      ]
    },
    {
      "title": "P99 Evaluation Latency (SLO: <5ms)",
      "type": "gauge",
      "gridPos": { "h": 5, "w": 6, "x": 12, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": {
          "unit": "ms",
          "max": 10,
          "thresholds": {
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 3 },
              { "color": "red", "value": 5 }
            ]
          }
        }
      },
      "targets": [
        {
          "expr": "histogram_quantile(0.99, sum(rate(vellaveto_evaluation_duration_seconds_bucket[5m])) by (le)) * 1000",
          "legendFormat": "P99 Latency"
        }
      ]
    },
    {
      "title": "Injection Scan Latency",
      "type": "timeseries",
      "gridPos": { "h": 5, "w": 6, "x": 18, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": {
          "unit": "ms"
        }
      },
      "targets": [
        {
          "expr": "histogram_quantile(0.99, sum(rate(vellaveto_injection_scan_duration_seconds_bucket[$__rate_interval])) by (le)) * 1000",
          "legendFormat": "P99 Injection Scan"
        }
      ]
    },
    {
      "title": "DLP Scan Latency",
      "type": "timeseries",
      "gridPos": { "h": 5, "w": 6, "x": 12, "y": 5 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": {
          "unit": "ms"
        }
      },
      "targets": [
        {
          "expr": "histogram_quantile(0.99, sum(rate(vellaveto_dlp_scan_duration_seconds_bucket[$__rate_interval])) by (le)) * 1000",
          "legendFormat": "P99 DLP Scan"
        }
      ]
    },
    {
      "title": "Evaluation Rate vs Latency",
      "type": "timeseries",
      "gridPos": { "h": 5, "w": 6, "x": 18, "y": 5 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": {
          "unit": "reqps"
        }
      },
      "targets": [
        {
          "expr": "sum(rate(vellaveto_evaluations_total[$__rate_interval]))",
          "legendFormat": "Evaluations/s"
        }
      ]
    },
    {
      "title": "Latency Heatmap",
      "type": "heatmap",
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 10 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "targets": [
        {
          "expr": "sum(increase(vellaveto_evaluation_duration_seconds_bucket[$__rate_interval])) by (le)",
          "format": "heatmap",
          "legendFormat": "{{le}}"
        }
      ]
    }
  ],
  "schemaVersion": 39,
  "tags": ["vellaveto", "performance", "latency"],
  "templating": {
    "list": [
      {
        "name": "datasource",
        "type": "datasource",
        "query": "prometheus"
      }
    ]
  },
  "time": { "from": "now-1h", "to": "now" },
  "title": "Vellaveto — Latency",
  "uid": "vellaveto-latency"
}
